{
  "name": "jarvis-fitness",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first MVP foundation for JarvisFitness",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "cli": "tsx src/cli.ts",
    "test": "node --test dist/tests/**/*.test.js"
  },
  "bin": {
    "jarvis-fitness": "dist/cli.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "express": "^5.1.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
